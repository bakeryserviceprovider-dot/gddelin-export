# Google Analytics (replace with your ID)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification (replace with your code)
NEXT_PUBLIC_GOOGLE_VERIFICATION=YOUR_GOOGLE_VERIFICATION_CODE

# SMTP Email Configuration (for contact form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# Notification recipient
CONTACT_EMAIL=info@gddelin.cn

# Optional: Telegram Bot alerts for new inquiries
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
